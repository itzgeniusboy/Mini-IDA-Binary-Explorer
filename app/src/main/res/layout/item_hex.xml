<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <!-- Virtual Address (Neon Green) -->
        <TextView
            android:id="@+id/tv_hex_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3.2"
            android:fontFamily="monospace"
            android:text="0x00010D00:"
            android:textColor="@color/neon_green"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Hex Bytes (White/Grey) -->
        <TextView
            android:id="@+id/tv_hex_bytes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4.8"
            android:fontFamily="monospace"
            android:text="7F 45 4C 46 02 01 01 00"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <!-- ASCII Text (Neon Cyan) -->
        <TextView
            android:id="@+id/tv_hex_ascii"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.0"
            android:fontFamily="monospace"
            android:gravity="end"
            android:text="⎾.ELF..⏌"
            android:textColor="@color/neon_cyan"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Visual Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="4dp"
        android:background="@color/border_color" />

</LinearLayout>
