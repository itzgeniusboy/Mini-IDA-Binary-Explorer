<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/dark_surface"
    app:cardCornerRadius="6dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Section Name -->
            <TextView
                android:id="@+id/tv_section_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=".text"
                android:textColor="@color/neon_green"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <!-- Section Size -->
            <TextView
                android:id="@+id/tv_section_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="2.4 KB"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </RelativeLayout>

        <!-- Address and Offset Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:weightSum="2">

            <!-- Virtual Address -->
            <TextView
                android:id="@+id/tv_section_addr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ADDR: 0x00010D00"
                android:textColor="@color/neon_cyan"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <!-- File Offset -->
            <TextView
                android:id="@+id/tv_section_offset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OFFSET: 0x00004500"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
