<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Navigation toolbar and search filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_margin="12dp">

        <Button
            android:id="@+id/btn_disasm_back"
            android:layout_width="44dp"
            android:layout_height="38dp"
            android:text="◀"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/dark_surface"
            android:padding="0dp"
            android:minWidth="44dp"
            android:enabled="false"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_disasm_forward"
            android:layout_width="44dp"
            android:layout_height="38dp"
            android:text="▶"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/dark_surface"
            android:padding="0dp"
            android:minWidth="44dp"
            android:enabled="false"
            android:layout_marginEnd="6dp" />

        <EditText
            android:id="@+id/et_disasm_filter"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:background="@color/dark_surface"
            android:hint="Search instructions..."
            android:textColorHint="#5A6075"
            android:textColor="#00FF66"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:fontFamily="sans-serif-monospace"
            android:textCursorDrawable="@null" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Layout with horizontal split for minimap and disassembly -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <!-- Highly Optimized RecyclerView for smooth scrolling on massive instruction sets -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:scrollbarStyle="outsideOverlay"
                android:scrollbars="vertical"
                android:scrollbarThumbVertical="@drawable/scrollbar_thumb_neon"
                android:scrollbarSize="4dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Vertical navigation minimap strip -->
            <androidx.compose.ui.platform.ComposeView
                android:id="@+id/minimap_compose_view"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Loading Placeholder -->
        <ProgressBar
            android:id="@+id/loading_indicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/neon_green"
            android:visibility="gone" />

        <!-- Empty State View -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textColor="@color/text_muted"
                android:textSize="40sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="NO DISASSEMBLY"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:text="Open a valid ELF binary to extract\nand disassemble the .text section."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
