<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_bg"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header with Neon Accent -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="MINI IDA"
                        android:textColor="@color/neon_green"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="ELF Binary Disassembler &amp; Analyzer"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btn_show_bookmarks"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/btn_star_big_on"
                        android:contentDescription="Show Bookmarks" />

                    <TextView
                        android:id="@+id/status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/dark_surface"
                        android:fontFamily="monospace"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp"
                        android:text="READY"
                        android:textColor="@color/neon_cyan"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Global Search Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/search_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/neon_green"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Search Icon" />

                    <EditText
                        android:id="@+id/et_global_search"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Global Search (Functions, Strings, Hex...)"
                        android:textColorHint="#5A6075"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:fontFamily="sans-serif-monospace"
                        android:textCursorDrawable="@null" />

                    <ProgressBar
                        android:id="@+id/pb_search_loading"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/neon_cyan"
                        style="?android:attr/progressBarStyleSmall" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Search Results Dropdown Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEARCH RESULTS"
                            android:textColor="@color/neon_cyan"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_close_search"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="[CLOSE]"
                            android:textColor="@color/neon_pink"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </RelativeLayout>

                    <!-- Scrollable results list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_search_results"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Loader Card with Neon Border Accent -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <!-- Inner layout for Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="monospace"
                        android:text="TARGET FILE:"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_file_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:ellipsize="middle"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:text="No file loaded (.so / .elf)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <!-- File Picker Trigger Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_file"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:fontFamily="monospace"
                        android:text="OPEN BINARY (.so / .elf)"
                        android:textColor="@color/neon_green"
                        android:textStyle="bold"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1.5dp" />

                    <!-- Decompile to C Button (Visible when binary loaded) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_decompile_file"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="DECOMPILE TO C"
                        android:textColor="@color/dark_bg"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:backgroundTint="@color/neon_cyan" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recent Files Section -->
            <LinearLayout
                android:id="@+id/layout_recent_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="monospace"
                    android:text="RECENT BINARIES"
                    android:textColor="@color/neon_cyan"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recent_files"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <!-- Persistent live-status bar/chip (updates in background during streaming analysis) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_analysis_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tv_analysis_status_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="ANALYZING BINARY (STREAMING)..."
                            android:textColor="@color/neon_green"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_analysis_status_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="monospace"
                            android:text="0%"
                            android:textColor="@color/neon_cyan"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btn_cancel_analysis"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/tv_analysis_status_progress"
                            android:layout_marginEnd="12dp"
                            android:text="[CANCEL]"
                            android:textColor="@color/neon_pink"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:clickable="true"
                            android:focusable="true" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tv_analysis_status_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="Initializing background streaming analysis..."
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <ProgressBar
                        android:id="@+id/pb_analysis_status"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:indeterminate="false"
                        android:progressTint="@color/neon_green"
                        android:progressBackgroundTint="@color/dark_bg" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Metadata Info Panel (Expanded dynamically) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/info_panel_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/dark_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="ELF HEADER INFO"
                        android:textColor="@color/neon_cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Class: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_class"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="ELF64"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Machine: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_machine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="AArch64"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Entry: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_entry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="0x10d00"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Endian: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_endian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="2's complement, little endian"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TabLayout styled to match dark and neon neon accents -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/dark_bg"
                app:tabBackground="@color/dark_bg"
                app:tabGravity="fill"
                app:tabIndicatorAnimationMode="elastic"
                app:tabIndicatorColor="@color/neon_green"
                app:tabIndicatorHeight="3dp"
                app:tabMode="fixed"
                app:tabRippleColor="@color/neon_cyan"
                app:tabSelectedTextColor="@color/neon_green"
                app:tabTextAppearance="@style/TabLayoutTextAppearance"
                app:tabTextColor="@color/text_secondary" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content area: ViewPager2 containing RecyclerView for strings, functions, hex -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
