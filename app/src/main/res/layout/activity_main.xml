<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_bg"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header with Neon Accent -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="MINI IDA"
                        android:textColor="@color/neon_green"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="ELF Binary Disassembler &amp; Analyzer"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/status_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@color/dark_surface"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:text="READY"
                    android:textColor="@color/neon_cyan"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Loader Card with Neon Border Accent -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <!-- Inner layout for Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="monospace"
                        android:text="TARGET FILE:"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_file_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:ellipsize="middle"
                        android:fontFamily="monospace"
                        android:singleLine="true"
                        android:text="No file loaded (.so / .elf)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <!-- File Picker Trigger Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_file"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:fontFamily="monospace"
                        android:text="OPEN BINARY (.so / .elf)"
                        android:textColor="@color/neon_green"
                        android:textStyle="bold"
                        app:strokeColor="@color/neon_green"
                        app:strokeWidth="1.5dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Metadata Info Panel (Expanded dynamically) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/info_panel_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/dark_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="monospace"
                        android:text="ELF HEADER INFO"
                        android:textColor="@color/neon_cyan"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Class: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_class"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="ELF64"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Machine: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_machine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="AArch64"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Entry: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_entry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="0x10d00"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Endian: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_elf_endian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="2's complement, little endian"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TabLayout styled to match dark and neon neon accents -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@color/dark_bg"
                app:tabBackground="@color/dark_bg"
                app:tabGravity="fill"
                app:tabIndicatorAnimationMode="elastic"
                app:tabIndicatorColor="@color/neon_green"
                app:tabIndicatorHeight="3dp"
                app:tabMode="fixed"
                app:tabRippleColor="@color/neon_cyan"
                app:tabSelectedTextColor="@color/neon_green"
                app:tabTextAppearance="@style/TabLayoutTextAppearance"
                app:tabTextColor="@color/text_secondary" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Content area: ViewPager2 containing RecyclerView for strings, functions, hex -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
