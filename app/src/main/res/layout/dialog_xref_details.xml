<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/dark_surface"
    android:padding="16dp">

    <!-- Dialog Header -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CROSS REFERENCES"
        android:textColor="@color/neon_green"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Called By Header -->
            <TextView
                android:id="@+id/tv_called_by_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CALLED BY (0)"
                android:textColor="#5A6075"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingBottom="4dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/container_called_by"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- Calls Header -->
            <TextView
                android:id="@+id/tv_calls_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CALLS (0)"
                android:textColor="#5A6075"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:paddingBottom="4dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/container_calls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
