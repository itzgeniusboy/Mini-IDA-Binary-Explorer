<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/dark_card"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:padding="12dp">

        <!-- File icon -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_menu_save"
            app:tint="@color/neon_cyan" />

        <!-- File details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- File Name -->
            <TextView
                android:id="@+id/tv_recent_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="libnative.so"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:ellipsize="middle"
                android:singleLine="true" />

            <!-- File Metadata (Size, Arch, Date) -->
            <TextView
                android:id="@+id/tv_recent_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:text="2.3 MB | ARM64 | Opened 2 hours ago"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Remove recent item button -->
        <ImageView
            android:id="@+id/iv_recent_remove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/neon_pink"
            android:padding="6dp"
            android:focusable="false"
            android:clickable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remove from recents" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
