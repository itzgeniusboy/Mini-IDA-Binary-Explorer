<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Scrollable Overview Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/overview_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clipToPadding="false"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Binary Status / Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BINARY METRICS"
                        android:textColor="@color/neon_cyan"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="12dp" />

                    <!-- File Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File Name:"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/tv_overview_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="libnative.so"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="10dp" />

                    <!-- File Size -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File Size:"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:id="@+id/tv_overview_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2 MB (1,234,567 bytes)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="10dp" />

                    <!-- Entropy & Packing Status -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shannon Entropy: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_overview_entropy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6.12 (Moderate)"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Packer Detected: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tv_overview_packer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None (Standard ELF)"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </GridLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ELF Header Fields -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/dark_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ELF HEADER STRUCTURE"
                        android:textColor="@color/neon_cyan"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="12dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignBounds"
                        android:useDefaultMargins="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Class/Width: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:id="@+id/tv_overview_class"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ELF64"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Endianness: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:id="@+id/tv_overview_endian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Little Endian"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Target CPU: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:id="@+id/tv_overview_machine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AArch64 (ARMv8-A)"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Entry Point: "
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:id="@+id/tv_overview_entry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0x00010D00"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sections List -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="SECTIONS &amp; SEGMENTS"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <LinearLayout
                android:id="@+id/layout_overview_sections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Placeholder -->
    <ProgressBar
        android:id="@+id/overview_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/neon_green"
        android:visibility="gone" />

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/overview_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📂"
            android:textColor="@color/text_muted"
            android:textSize="40sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="NO BINARY LOADED"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="Click above to open and parse\na shared object library or ELF binary."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

</FrameLayout>
