<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/dark_surface"
    app:cardCornerRadius="4dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <!-- Offset address in neon green -->
            <TextView
                android:id="@+id/tv_string_offset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="0x00010DF2"
                android:textColor="@color/neon_green"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Reference count indicator in cyber magenta/pink -->
            <TextView
                android:id="@+id/tv_string_xref_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/tv_string_offset"
                android:layout_marginStart="12dp"
                android:fontFamily="monospace"
                android:text="referenced by 0 functions"
                android:textColor="#FF007F"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Length label in neon cyan -->
            <TextView
                android:id="@+id/tv_string_len"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="monospace"
                android:text="LEN: 14"
                android:textColor="@color/neon_cyan"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- String text value -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_string_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:text="/system/lib64/libutils.so"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/iv_string_bookmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/btn_star_big_off"
                android:padding="4dp"
                android:focusable="false"
                android:clickable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmark string" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
