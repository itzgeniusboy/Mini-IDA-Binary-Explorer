<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApplication" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/neon_green</item>
        <item name="colorPrimaryVariant">@color/neon_cyan</item>
        <item name="colorOnPrimary">@color/dark_bg</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/neon_cyan</item>
        <item name="colorSecondaryVariant">@color/neon_cyan</item>
        <item name="colorOnSecondary">@color/dark_bg</item>

        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Customize your theme here. -->
        <item name="colorContainer">@color/dark_card</item>
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
    </style>

    <style name="TabLayoutTextAppearance" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
